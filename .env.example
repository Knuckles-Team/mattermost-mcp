# Mattermost Server API v4 endpoint URL
MATTERMOST_URL=http://localhost:8065
# Personal Access Token or Bot Token
MATTERMOST_TOKEN=mattermost_api_access_token

# --- Tool Toggle Switches (per-domain <DOMAIN>TOOL; set False to disable) ---
